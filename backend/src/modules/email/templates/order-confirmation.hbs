<!DOCTYPE html>
<html lang="vi">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Xác nhận đơn hàng</title>
</head>
<body style="margin:0;padding:0;background:#f5f5f5;font-family:Arial,Helvetica,sans-serif;">
  <table width="100%" cellpadding="0" cellspacing="0" style="background:#f5f5f5;padding:40px 20px;">
    <tr>
      <td align="center">
        <table width="600" cellpadding="0" cellspacing="0" style="background:#ffffff;border-radius:8px;overflow:hidden;max-width:600px;width:100%;">
          <!-- Header -->
          <tr>
            <td style="background:#ee4d2d;padding:32px 40px;text-align:center;">
              <h1 style="margin:0;color:#ffffff;font-size:28px;font-weight:700;">ShopeeClone</h1>
              <p style="margin:8px 0 0;color:#ffccbb;font-size:14px;">Xác nhận đơn hàng</p>
            </td>
          </tr>
          <!-- Body -->
          <tr>
            <td style="padding:40px;">
              <h2 style="margin:0 0 8px;color:#212121;font-size:22px;">Xin chào {{fullName}},</h2>
              <p style="margin:0 0 24px;color:#555555;font-size:15px;line-height:1.6;">
                Đơn hàng <strong>#{{orderCode}}</strong> của bạn đã được đặt thành công.
                Chúng tôi sẽ xử lý đơn hàng của bạn trong thời gian sớm nhất.
              </p>

              <!-- Order Items -->
              <table width="100%" cellpadding="0" cellspacing="0" style="border:1px solid #eeeeee;border-radius:6px;overflow:hidden;margin-bottom:24px;">
                <tr style="background:#f9f9f9;">
                  <td style="padding:12px 16px;font-size:13px;font-weight:700;color:#555555;">Sản phẩm</td>
                  <td style="padding:12px 16px;font-size:13px;font-weight:700;color:#555555;text-align:center;">SL</td>
                  <td style="padding:12px 16px;font-size:13px;font-weight:700;color:#555555;text-align:right;">Thành tiền</td>
                </tr>
                {{#each items}}
                <tr style="border-top:1px solid #eeeeee;">
                  <td style="padding:12px 16px;font-size:14px;color:#212121;">
                    {{this.productName}}
                    {{#if this.variantOptions}}
                    <br /><span style="color:#888;font-size:12px;">{{this.variantOptions}}</span>
                    {{/if}}
                  </td>
                  <td style="padding:12px 16px;font-size:14px;color:#212121;text-align:center;">{{this.quantity}}</td>
                  <td style="padding:12px 16px;font-size:14px;color:#212121;text-align:right;">{{this.totalPrice}} ₫</td>
                </tr>
                {{/each}}
              </table>

              <!-- Order Summary -->
              <table width="100%" cellpadding="0" cellspacing="0" style="margin-bottom:24px;">
                <tr>
                  <td style="padding:6px 0;font-size:14px;color:#555555;">Tạm tính:</td>
                  <td style="padding:6px 0;font-size:14px;color:#212121;text-align:right;">{{subtotal}} ₫</td>
                </tr>
                <tr>
                  <td style="padding:6px 0;font-size:14px;color:#555555;">Phí vận chuyển:</td>
                  <td style="padding:6px 0;font-size:14px;color:#212121;text-align:right;">{{shippingFee}} ₫</td>
                </tr>
                <tr style="border-top:2px solid #eeeeee;">
                  <td style="padding:12px 0 6px;font-size:16px;font-weight:700;color:#212121;">Tổng cộng:</td>
                  <td style="padding:12px 0 6px;font-size:16px;font-weight:700;color:#ee4d2d;text-align:right;">{{total}} ₫</td>
                </tr>
              </table>

              <!-- Shipping Address -->
              <div style="background:#f9f9f9;border-radius:6px;padding:16px;margin-bottom:24px;">
                <p style="margin:0 0 8px;font-size:13px;font-weight:700;color:#555555;text-transform:uppercase;">Địa chỉ giao hàng</p>
                <p style="margin:0;font-size:14px;color:#212121;line-height:1.6;">
                  {{shippingAddress.fullName}} — {{shippingAddress.phone}}<br />
                  {{shippingAddress.address}}
                </p>
              </div>

              <div style="text-align:center;">
                <a href="{{orderUrl}}"
                   style="display:inline-block;background:#ee4d2d;color:#ffffff;padding:14px 36px;border-radius:6px;text-decoration:none;font-size:15px;font-weight:600;">
                  Xem đơn hàng
                </a>
              </div>
            </td>
          </tr>
          <!-- Footer -->
          <tr>
            <td style="background:#f9f9f9;padding:20px 40px;text-align:center;">
              <p style="margin:0;color:#aaaaaa;font-size:12px;">© 2025 ShopeeClone. Tất cả quyền được bảo lưu.</p>
            </td>
          </tr>
        </table>
      </td>
    </tr>
  </table>
</body>
</html>
